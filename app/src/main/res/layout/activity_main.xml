<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/card_background"
        android:elevation="4dp">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:background="@android:drawable/edit_text"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:inputType="text"
            android:maxLines="1"/>

        <Button
            android:id="@+id/selectAllButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/select_all"
            android:layout_marginStart="8dp"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/clearAllButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/clear_all"
            android:layout_marginStart="4dp"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- 产品列表区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/productListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- 底部控制面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/card_background"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/highlightCheckBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/highlight_winner"
            android:checked="true"/>

        <RadioGroup
            android:id="@+id/modeRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp">

            <RadioButton
                android:id="@+id/rainbowMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_rainbow"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/lineStyleMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_linestyle"
                android:layout_marginStart="8dp"/>
        </RadioGroup>

        <Button
            android:id="@+id/confirmButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/confirm"
            android:layout_marginStart="16dp"
            android:backgroundTint="@color/primary"/>
    </LinearLayout>

</LinearLayout>